PORT=8080

# Protects /api/* and /api/v1/events. Leave empty only for local development.
API_TOKEN=replace-with-a-long-random-token

POLL_INTERVAL=30s
UPSTREAM_TIMEOUT=10s

# Beszel/PocketBase. Use a dedicated read-only Beszel user.
BESZEL_URL=http://beszel:8090
BESZEL_IDENTITY=
BESZEL_PASSWORD=
BESZEL_COLLECTION_SYSTEMS=systems
BESZEL_COLLECTION_SYSTEM_STATS=system_stats
BESZEL_COLLECTION_CONTAINERS=containers
BESZEL_COLLECTION_CONTAINER_STATS=container_stats
BESZEL_COLLECTION_REALTIME=rt_metrics
BESZEL_COLLECTION_ALERTS=alerts

# Uptime Kuma Prometheus endpoint. Prefer a dedicated metrics API key.
UPTIME_KUMA_URL=http://uptime-kuma:3001
UPTIME_KUMA_API_KEY=
